# =========================
# BASE
# =========================

FROM python:3.13-slim

# =========================
# SYSTEM DEPS
# =========================

RUN apt-get update && apt-get install -y \
    wget \
    curl \
    gnupg \
    unzip \
    fonts-liberation \
    libasound2 \
    libatk-bridge2.0-0 \
    libatk1.0-0 \
    libcups2 \
    libdbus-1-3 \
    libdrm2 \
    libgbm1 \
    libgtk-3-0 \
    libnspr4 \
    libnss3 \
    libu2f-udev \
    libxcomposite1 \
    libxdamage1 \
    libxfixes3 \
    libxkbcommon0 \
    libxrandr2 \
    xdg-utils \
    libxshmfence1 \
    libglu1-mesa \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# =========================
# WORKDIR
# =========================

WORKDIR /app

# =========================
# ENV
# =========================

ENV PYTHONUNBUFFERED=1
ENV PLAYWRIGHT_BROWSERS_PATH=/ms-playwright

# =========================
# INSTALL PYTHON DEPS
# =========================

COPY requirements.txt .

RUN pip install --no-cache-dir -r requirements.txt

# =========================
# INSTALL PLAYWRIGHT
# =========================

RUN playwright install chromium

# =========================
# COPY APP
# =========================

COPY . .

# =========================
# PORT
# =========================

EXPOSE 8000

# =========================
# START
# =========================

CMD ["python", "main.py"]